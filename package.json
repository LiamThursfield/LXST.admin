{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently -p \"[{name}]\" -n \"Central,Tenant\" -c \"bgBlue,bgMagenta\" \"pnpm dev:central\" \"pnpm dev:tenant\"",
        "dev:central": "vite --config vite.central.config.ts",
        "dev:tenant": "vite --config vite.tenant.config.ts",
        "build": "pnpm build:central && pnpm build:tenant",
        "build:central": "vite build --config vite.central.config.ts",
        "build:tenant": "vite build --config vite.tenant.config.ts",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^22.19.15",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/eslint-config-typescript": "^14.7.0",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^9.33.0",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^7.3.1",
        "vue-tsc": "^2.2.12"
    },
    "dependencies": {
        "@inertiajs/vue3": "^2.3.18",
        "@nuxt/ui": "^4.5.1",
        "@unovis/vue": "^1.6.4",
        "@vueuse/core": "^12.8.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "laravel-vite-plugin": "^2.1.0",
        "lucide-vue-next": "^0.468.0",
        "reka-ui": "^2.9.2",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "vue": "^3.5.30",
        "vue-input-otp": "^0.3.2",
        "zod": "^4.3.6"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@rollup/rollup-win32-x64-msvc": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
        "lightningcss-linux-x64-gnu": "^1.32.0",
        "lightningcss-win32-x64-msvc": "^1.32.0"
    }
}
